# Copiez ce fichier en .env et remplissez les valeurs

# Clé API Anthropic (optionnel - active l'assistant IA complet)
# Sans cette clé, l'assistant fonctionne en mode dégradé (réponses basiques)
# Obtenez une clé sur: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Base de données (ne pas modifier si vous utilisez Docker)
DATABASE_URL=postgresql+asyncpg://sad_user:sad_pass_2024@postgres:5432/sad_db

# Sécurité (changez cette valeur en production!)
SECRET_KEY=sad-secret-key-cameroun-2024-changez-moi
